{
  "name": "@pccbot/discord-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker brain for PPC Discord interactions, site health, and web-to-Discord automation.",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --port 8788",
    "register": "tsx src/register.ts",
    "register:global": "tsx src/register.ts --scope global --cleanup-guild",
    "register:guild": "tsx src/register.ts --scope guild --cleanup-global",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@pccbot/shared": "file:../../packages/shared",
    "discord-interactions": "^4.4.0",
    "itty-router": "^5.0.23"
  }
}
